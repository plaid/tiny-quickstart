# Copy this file to .env and fill out each variable
# NOTE: To use Production, you must set a use case for Link.
# You can do this in the Dashboard under Link -> Link Customization -> Data Transparency:
# https://dashboard.plaid.com/link/data-transparency-v5

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional. If set, the app will register this URL as the webhook for
# the Link session. The /webhook handler will exchange the public_token
# delivered via SESSION_FINISHED instead of calling /link/token/get from
# /complete. Must be a publicly reachable URL — use ngrok or similar
# during local development.
PLAID_WEBHOOK_URL=
